@startuml
autonumber

actor "Usuário" as U
participant "Frontend" as FE
participant "DiagnosticoInicialController" as DC
participant "DiagnosticoInicialService" as DS
participant "ReceitawsApiService" as RS
participant "AnaliseMigracaoService" as AMS
participant "PrismaService" as DB

== 1) Consulta de CNPJ ==
U -> FE : Digita CNPJ
FE -> DC : GET /diagnostico-inicial/cnpj/{cnpj}
DC -> DS : findCnpjData(cnpj)
DS -> RS : findOne(cnpj)
RS -> "ReceitaWS API" : GET /v1/cnpj/{cnpj}
"ReceitaWS API" --> RS : Dados cadastrais
RS --> DS : Dados da empresa
DS --> DC : Payload de pré-preenchimento
DC --> FE : 200 OK

== 2) Criação de diagnóstico ==
U -> FE : Confirma dados e envia formulário
FE -> DC : POST /diagnostico-inicial
DC -> DS : create(dto, user)
DS -> AMS : analisar(mei, cnaesPermitidos)
AMS --> DS : status + análise + motivos
DS -> DB : upsert Mei
DS -> DB : upsert Diagnostico
DB --> DS : Persistência concluída
DS --> DC : Diagnóstico consolidado
DC --> FE : 201 Created

== 3) Consulta por usuário ==
FE -> DC : GET /diagnostico-inicial
DC -> DS : findByUser(user.id_user)
DS -> DB : Busca Mei + Diagnostico + Analise
DB --> DS : Dados consolidados
DS --> DC : Resultado final
DC --> FE : 200 OK
@enduml
